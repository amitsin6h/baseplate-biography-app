# Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only needed on the server / edge functions — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — used by biography edge functions
OPENAI_API_KEY=sk-...
# Required by feature spec for webhook signature verification.
# Not consumed in this MVP implementation (generation runs inline, no webhook callback).
OPENAI_WEBHOOK_SECRET=your-openai-webhook-secret

# Diffbot — used by biography-fetch-profile-from-url
DIFFBOT_API_KEY=your-diffbot-token
